---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SummerCamp from '../components/SummerCamp.astro';
import Animals from '../components/Animals.astro';
import VisitUs from '../components/VisitUs.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Firebelly Farm — Where Days Smell Like Hay & Happiness"
  description="Family hobby farm and summer camps for kids in the Cowichan Valley, BC. Horses, chickens, and unforgettable summer memories."
>
  <Nav />
  <Hero />
  <div class="wavy">~ ~ ~ ~ ~ ~ ~ ~</div>
  <SummerCamp />
  <Animals />
  <VisitUs />
  <Footer />
</BaseLayout>

<style>
  .wavy {
    text-align: center;
    font-size: 28px;
    letter-spacing: 8px;
    padding: 8px 0;
    color: #f5c99a;
    background: #fff5ed;
  }
</style>
