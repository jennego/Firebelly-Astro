// resolve weight → path content
const iconDef = icons[name];
const pathContent = iconDef
  ? (iconDef[weight] ?? iconDef['fill'] ?? iconDef['regular'] ?? Object.values(iconDef)[0])
  : null;
---

{pathContent ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 256 256"
    class={className}
    aria-hidden={ariaHidden === true ? 'true' : ariaHidden}
    aria-label={ariaLabel}
    fill={weight === 'regular' || weight === 'light' || weight === 'thin' ? 'none' : color}
    stroke={weight === 'fill' ? 'none' : color}
    stroke-width={weight === 'thin' ? 8 : weight === 'light' ? 12 : 16}
    stroke-linecap="round"
    stroke-linejoin="round"
    set:html={pathContent}
  />
) : (
  <span class={className} style={`display:inline-block;width:${size}px;height:${size}px;background:#f5c99a;border-radius:4px;`} aria-label={`Missing icon: ${name}`} />
)}
