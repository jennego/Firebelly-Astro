---
const details = [

  { icon: '🎠', text: 'Pony rides and first time rides.' },

  { icon: '☀️', text: 'Lessons available at our facility in dry months only.' },

  { icon: '⭐', text: 'EC-certified coaching with a focus on confidence-building and fun' },

  { icon: '📚', text: 'Equestrian Canada Rider Level testing available' },

];

const disciplines = [
  { name: 'Jumpers',  current: true  },
  { name: 'Eventing', current: false },
  { name: 'Dressage', current: false },
  { name: 'Flat work',current: false },
];

const photos = [
  { src: null, alt: 'Lesson in the paddock' },
  { src: null, alt: 'Jumping session' },
  { src: null, alt: 'Pony ride' },
];
---

<section id="lessons" class="lessons-section">
  <div class="lessons-inner">
    <p class="section-label">Ride with us</p>
    <h2 class="section-title">Lessons &amp; Pony Rides</h2>
    <p class="section-sub">
      
    </p>

    <!-- Single content card -->
    <div class="lessons-card">
      <div class="card-left">
        <h3>Lessons &amp; Rides at Firebelly</h3>
        <p>
          Leora offers some riding lessons on our horses in the summer months and is may travel locally in the Cowichan Valley to to coach on your horse. Pricing and availability vary,
          so reach out through the contact form to discuss. 
        </p>
  
        <div class="card-cta">
          <a href="#contact" class="cta-btn">Inquire About Lessons →</a>
        </div>
      </div>

      <div class="card-right">
        <ul class="detail-list">
          {details.map((d) => (
            <li>
              <span class="d-icon">{d.icon}</span>
              <span>{d.text}</span>
            </li>
          ))}
        </ul>

        <!-- Photo placeholders -->
        <div class="photo-grid">
          {photos.map((p) => (
            <div class="photo-cell">
              {p.src
                ? <img src={p.src} alt={p.alt} />
                : (
                  <div class="photo-placeholder">
                    <div class="ph-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <path d="M21 15l-5-5L5 21"/>
                      </svg>
                    </div>
                    <p>{p.alt}</p>
                  </div>
                )
              }
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .lessons-section {
    background: #fef2e7;
    padding: 64px 32px;
  }

  .lessons-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #c0390b;
    margin-bottom: 6px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #8b2500;
    margin-bottom: 10px;
  }

  .section-sub {
    color: #7a4030;
    margin-bottom: 40px;
    line-height: 1.75;
    max-width: 640px;
  }

  /* ── Card ── */
  .lessons-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #fff;
    border-radius: 20px;
    border: 1.5px solid #f5c99a;
    overflow: hidden;
  }

  /* Left — gradient panel */
  .card-left {
    background: linear-gradient(160deg, #c0390b, #e8560a, #f5820a);
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
  }

  .age-badge {
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 18px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    width: fit-content;
  }

  .card-left h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    color: #fff;
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .card-left > p {
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.75;
    margin-bottom: 28px;
    flex: 1;
  }

  .disciplines-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 10px;
  }

  .disc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }

  .disc-pill {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 20px;
  }

  .disc-pill.current {
    background: rgba(255, 255, 255, 0.28);
    border-color: rgba(255, 255, 255, 0.55);
  }

  .card-cta {
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
  }

  .cta-btn {
    display: inline-block;
    background: #fff;
    color: #c0390b;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    padding: 13px 28px;
    border-radius: 50px;
    text-decoration: none;
    transition: transform 0.15s, background 0.15s;
  }

  .cta-btn:hover {
    transform: scale(1.03);
    background: #fff5ed;
  }

  /* Right — white panel */
  .card-right {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .detail-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .detail-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #4a2810;
    line-height: 1.6;
  }

  .d-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Photo grid — 3 equal cells */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .photo-cell {
    border-radius: 10px;
    overflow: hidden;
    background: #e8d5c0;
    aspect-ratio: 1;
  }

  .photo-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px;
    text-align: center;
  }

  .ph-icon {
    width: 32px;
    height: 32px;
    background: #f5dfc8;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ph-icon svg {
    width: 18px;
    height: 18px;
    color: #c07040;
  }

  .photo-placeholder p {
    font-size: 0.6rem;
    color: #b07050;
    font-weight: 600;
    line-height: 1.3;
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .lessons-section { padding: 48px 20px; }

    .lessons-card {
      grid-template-columns: 1fr;
    }

    .card-left  { padding: 32px 24px; }
    .card-right { padding: 28px 24px; }

    .photo-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
