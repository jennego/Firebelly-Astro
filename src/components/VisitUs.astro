---
const chips = [
  { icon: '📍', text: 'Rural Route 4, Cowichan Valley' },
  { icon: '🕐', text: 'Sat–Sun, 10am–4pm' },
  { icon: '🥚', text: 'Fresh eggs daily' },
  { icon: '🐴', text: 'Pony rides $10' },
];
---

<section id="visit-us" class="visit-section">
  <h2>Come Visit the Farm</h2>
  <p>
    Day visits welcome every weekend May through September. Pick up fresh eggs, meet the animals,
    and breathe some fresh country air.
  </p>
  <div class="chips">
    {chips.map((chip) => (
      <div class="chip">{chip.icon} {chip.text}</div>
    ))}
  </div>
  <a href="https://maps.google.com" target="_blank" rel="noopener noreferrer" class="btn-primary">
    Get Directions
  </a>
</section>

<style>
  .visit-section {
    background: linear-gradient(135deg, #8b2500, #c0390b, #e8560a);
    padding: 64px 32px;
    text-align: center;
  }

  .visit-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 40px;
    color: #fff;
    margin-bottom: 16px;
  }

  .visit-section p {
    font-size: 16px;
    color: #ffe4cc;
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .chips {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }

  .chip {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 14px;
    font-weight: 600;
    padding: 8px 20px;
    border-radius: 30px;
  }

  .btn-primary {
    background: #fff;
    color: #c0390b;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 16px;
    padding: 14px 36px;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.15s;
  }

  .btn-primary:hover {
    transform: scale(1.04);
  }
</style>
