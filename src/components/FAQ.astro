---
const faqs = [
  {
    category: 'Summer Camp',
    questions: [
      {
        q: 'What ages is camp suitable for?',
        a: 'Camp is designed for kids ages 5+. If you\'re unsure whether your child is a good fit, just reach out. Leora is happy to chat about it.',
      },
        {
        q: 'Where is camp?',
        a: 'Camp is at Firebelly Farm, just north of Duncan on Vancouver Island. We are close to Cowichan Exhibition.',
      },
      {
        q: 'Does my child need riding experience?',
        a: 'Not at all! Camp welcomes complete beginners and more advanced riders.',
      },
      {
        q: 'What are the drop-off and pick-up times?',
        a: 'Drop-off is from 8–9am and pick-up is between 3–4pm. Please let Leora know if you need a slightly different arrangement.',
      },
      {
        q: 'Does my child need a riding helmet?',
        a: 'Yes — a well-fitted, certified riding helmet is required for all equestrian activities. We recommend shopping at April\'s Tack Boutique, The Trading Post, or Buckerfield\'s. Call ahead to check sizing availability.',
      },
      {
        q: 'What should my child bring on Day 1?',
        a: 'On Day 1, please send your child with a bathing suit (or clothes they can get wet in), a towel, and a painting smock or oversized t-shirt. These can stay at Firebelly for the week in a small bag.',
      },
      {
        q: 'Are there allergy or dietary accommodations?',
        a: 'We are peanut, dairy, and gluten friendly by default. If your child has specific allergies or dietary needs, please let us know in advance so we can plan accordingly — we may not be able to accommodate every requirement.',
      },
      {
        q: 'Can my child bring their phone?',
        a: 'Please leave phones and tablets at home! If you need to reach your child during camp, Leora is available by text or . If there\'s a specific reason your child needs a phone, let\'s have a conversation about it.',
      },
      {
        q: 'How do I register?',
        a: 'Use the Register Now button in the Summer Camp section — Leora will get in touch with you about next steps.'
      },
    ],
  },
  {
    category: 'Lessons & Rides',
    questions: [
      {
        q: 'Do you offer riding lessons outside of camp?',
        a: 'Yes! Get in touch through the contact form to discuss availability and scheduling.',
      },
      {
        q: 'Are pony rides available for younger children?',
        a: 'Yes — pony rides are available for younger or first-time riders in a safe, guided setting. Contact us to arrange a visit.',
      },
      {
        q: 'What kind of riding does Leora teach?',
        a: 'Leora\'s teaches English riding. Her background includes dressage, eventing and jumpers. She tailors lessons to your goals.',
      },
    ],

  },
];
---

<section id="faq" class="faq-section">
  <div class="faq-inner">
    <p class="section-label">Got questions?</p>
    <h2 class="section-title">Frequently Asked Questions</h2>
    <p class="section-sub">
      Can't find what you're looking for? Drop us a note through the <a href="#contact">contact form</a> and Leora will get back to you.
    </p>

    <div class="faq-groups">
      {faqs.map((group) => (
        <div class="faq-group">
          <h3 class="faq-group-title">{group.category}</h3>
          <div class="faq-list">
            {group.questions.map((item, i) => (
              <details class="faq-item" id={`faq-${group.category}-${i}`}>
                <summary class="faq-question">
                  <span>{item.q}</span>
                  <span class="faq-chevron" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </span>
                </summary>
                <div class="faq-answer">
                  <p>{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    background: #fef2e7;
    padding: 64px 32px;
  }

  .faq-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #c0390b;
    margin-bottom: 6px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #8b2500;
    margin-bottom: 10px;
  }

  .section-sub {
    color: #7a4030;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .section-sub a {
    color: #c0390b;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Groups ── */
  .faq-groups {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .faq-group-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #c0390b;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f5c99a;
  }

  /* ── Accordion items ── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .faq-item {
    background: #fff;
    border: 1.5px solid #f5c99a;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .faq-item[open] {
    border-color: #e8560a;
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    cursor: pointer;
    font-weight: 700;
    color: #2d1a0e;
    list-style: none;
    user-select: none;
    transition: background 0.15s;
  }

  /* Remove default triangle in all browsers */
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::marker { display: none; }

  .faq-question:hover {
    background: #fff5ed;
  }

  .faq-item[open] .faq-question {
    background: #fff5ed;
    color: #8b2500;
  }

  .faq-chevron {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: #c0390b;
    transition: transform 0.25s ease;
  }

  .faq-chevron svg {
    width: 100%;
    height: 100%;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 20px 18px;
    color: #4a2810;
    line-height: 1.75;
    border-top: 1px solid #f5e0cc;
    margin-top: -1px;
  }

  .faq-answer p {
    padding-top: 14px;
  }

  @media (max-width: 640px) {
    .faq-section { padding: 48px 20px; }
  }
</style>
